local Rayfield = loadstring(game:HttpGet('https://sirius.menu'))()

local Window = Rayfield:CreateWindow({
   Name = "Awesome Hub MM2",
   LoadingTitle = "Loading...",
   LoadingSubtitle = "by Awesome Crack",
   ConfigurationSaving = {Enabled = true, FolderName = "AwesomeHubData", FileName = "Config"},
   KeySystem = false
})

local Tab = Window:CreateTab("Main", nil)

Tab:CreateSection("Movement")
Tab:CreateSlider({
   Name = "Speed",
   Range = {16, 200},
   Increment = 1,
   CurrentValue = 16,
   Callback = function(Value) game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value end,
})

Tab:CreateSection("Game")
Tab:CreateButton({
   Name = "ESP Players",
   Callback = function()
      for _, v in pairs(game.Players:GetPlayers()) do
         if v ~= game.Players.LocalPlayer and v.Character then
            local hl = Instance.new("Highlight", v.Character)
            hl.FillTransparency = 0.5
         end
      end
   end,
})

Tab:CreateButton({
   Name = "Check Roles",
   Callback = function()
      for _, v in pairs(game.Players:GetPlayers()) do
         if v.Backpack:FindFirstChild("Knife") or (v.Character and v.Character:FindFirstChild("Knife")) then
            Rayfield:Notify({Title = "Role", Content = v.Name .. " is Murderer!"})
         end
      end
   end,
})
