local Rayfield = loadstring(game:HttpGet('https://sirius.menu'))()

local Window = Rayfield:CreateWindow({
   Name = "MM2 Awesome Hub V2",
   LoadingTitle = "Executing Script...",
   LoadingSubtitle = "by Awesome Crack Hub",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "AwesomeHub_MM2",
      FileName = "Config"
   },
   Discord = {Enabled = false},
   KeySystem = false,
})

local TabMain = Window:CreateTab("Main", nil)
local TabVisuals = Window:CreateTab("Visuals", nil)
local TabPlayer = Window:CreateTab("Player", nil)

local SectionFarm = TabMain:CreateSection("Auto Farm")
TabMain:CreateToggle({
   Name = "Auto Collect Coins",
   CurrentValue = false,
   Callback = function(Value)
        _G.AutoFarm = Value
        while _G.AutoFarm do
            task.wait(0.1)
            local Container = workspace:FindFirstChild("CoinContainer", true)
            if Container then
                for _, coin in pairs(Container:GetChildren()) do
                    if coin:IsA("BasePart") and _G.AutoFarm then
                        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = coin.CFrame
                        task.wait(0.3)
                    end
                end
            end
        end
   end,
})

local SectionRoles = TabMain:CreateSection("Game Status")
TabMain:CreateButton({
   Name = "Check Roles (Killer/Sheriff)",
   Callback = function()
        for _, v in pairs(game.Players:GetPlayers()) do
            if v.Backpack:FindFirstChild("Knife") or (v.Character and v.Character:FindFirstChild("Knife")) then
                Rayfield:Notify({Title = "FOUND", Content = "Murderer: " .. v.Name, Duration = 5})
            elseif v.Backpack:FindFirstChild("Gun") or (v.Character and v.Character:FindFirstChild("Gun")) then
                Rayfield:Notify({Title = "FOUND", Content = "Sheriff: " .. v.Name, Duration = 5})
            end
        end
   end,
})

local SectionESP = TabVisuals:CreateSection("ESP Settings")
TabVisuals:CreateToggle({
   Name = "Player ESP",
   CurrentValue = false,
   Callback = function(Value)
        _G.ESP = Value
        while _G.ESP do
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character and not v.Character:FindFirstChild("Highlight") then
                    local hl = Instance.new("Highlight", v.Character)
                    hl.FillTransparency = 0.5
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                end
            end
            task.wait(1)
            if not _G.ESP then
                for _, v in pairs(game.Players:GetPlayers()) do
                    if v.Character and v.Character:FindFirstChild("Highlight") then
                        v.Character.Highlight:Destroy()
                    end
                end
            end
        end
   end,
})

local SectionStats = TabPlayer:CreateSection("Movement")
TabPlayer:CreateSlider({
   Name = "WalkSpeed",
   Range = {16, 200},
   Increment = 1,
   CurrentValue = 16,
   Callback = function(Value)
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
   end,
})

TabPlayer:CreateSlider({
   Name = "JumpPower",
   Range = {50, 250},
   Increment = 1,
   CurrentValue = 50,
   Callback = function(Value)
        game.Players.LocalPlayer.Character.Humanoid.JumpPower = Value
   end,
})

TabPlayer:CreateButton({
   Name = "Infinite Jump",
   Callback = function()
        game:GetService("UserInputService").JumpRequest:Connect(function()
            game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
        end)
   end,
})

Rayfield:LoadConfiguration()
